{
  "name": "__PROJECT_NAME_PKG__",
  "private": true,
  "version": "0.1.0",
  "description": "PostgreSQL-first TypeScript app generated for __PROJECT_NAME__.",
  "workspaces": [
    "server",
    "web"
  ],
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w web\"",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "tsx db/scripts/migrate.ts",
    "db:seed": "tsx db/scripts/seed.ts",
    "test:db": "tsx db/scripts/test-db.ts",
    "test:server": "npm run test -w server",
    "test:web": "npm run test -w web",
    "test:e2e": "npm run test:e2e -w web",
    "test": "npm run test:db && npm run test:server && npm run test:web",
    "typecheck": "npm run typecheck -w server && npm run typecheck -w web",
    "lint": "npm run typecheck",
    "agent:check": "tsx scripts/checks/check-agent-drift.ts",
    "agent:check:contract": "tsx scripts/checks/check-contract-coverage.ts"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "concurrently": "^9.1.2",
    "pg": "^8.16.3",
    "tsx": "^4.22.4"
  }
}
